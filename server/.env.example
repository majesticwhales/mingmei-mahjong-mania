# Copy to .env and adjust as needed
DATABASE_URL=postgres://postgres:postgres@localhost:5433/mingmei_mahjong_mania
# Separate DB for tests (create once: CREATE DATABASE mingmei_mahjong_mania_test;)
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/mingmei_mahjong_mania_test
NODE_ENV=development
PORT=3001
JWT_SECRET=your-256-bit-secret
JWT_EXPIRES_IN=7d
# Allow starting a game with 1 player in development (set false to enforce full lobby rules)
DEV_RELAX_LOBBY_START=true
# Production hosts who may start with fewer than four players (comma-separated; default: waterbug,nobadinohz)
# RELAX_LOBBY_START_USERNAMES=waterbug,nobadinohz
